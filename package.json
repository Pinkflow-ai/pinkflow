    "tailwindcss": "4.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "typescript": "5.7.2",
    "vitest": "4.1.10",
    "wrangler": "^4.26.0"
  }
}
