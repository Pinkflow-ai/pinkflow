---
import { site } from '../data/site';
const year = new Date().getFullYear();
const links = [
  { href: '/pricing', label: 'Pricing' },
  { href: '/terms', label: 'Terms' },
  { href: '/privacy', label: 'Privacy' },
  { href: '/refunds', label: 'Refunds' },
  { href: '/contact', label: 'Contact' },
];
---
<footer class="no-print mt-16 border-t border-primary/10 px-4 py-8 text-sm text-white/50">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-3 md:flex-row md:justify-between">
    <div class="flex items-center gap-2">
      <span class="inline-block h-2 w-2 rounded-full bg-primary"></span>
      <span>&copy; {year} {site.brand}. All rights reserved.</span>
    </div>
    <nav class="flex flex-wrap items-center justify-center gap-4">
      {links.map((l) => <a href={l.href} class="hover:text-white">{l.label}</a>)}
    </nav>
  </div>
  <p class="mx-auto mt-4 max-w-5xl text-center text-xs text-white/40 md:text-left">
    {site.operatorLine}. Paddle is the {site.paddle.role.toLowerCase()} for payments.
  </p>
</footer>
