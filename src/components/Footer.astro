---
import { site } from '../data/site';
const year = new Date().getFullYear();
const links = [
  { href: '/terms', label: 'Terms' },
  { href: '/privacy', label: 'Privacy' },
  { href: '/refunds', label: 'Refunds' },
];
---
<footer class="no-print mt-20 border-t border-primary/10 px-4 py-10 text-sm text-white/55 sm:px-6">
  <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <div class="flex items-center gap-2 font-extrabold text-white">
        <span class="inline-block h-2 w-2 rounded-full bg-primary"></span>
        Pinkflow.ai
      </div>
      <p class="mt-3 max-w-sm leading-relaxed">
        Products in progress, with plain facts and a direct way to reach us.
      </p>
    </div>
    <nav aria-label="Products and company" class="flex flex-col items-start gap-2">
      <a href="/#products" class="hover:text-white">Products</a>
      <a href="/pricing" class="hover:text-white">Pricing</a>
      <a href="/contact" class="hover:text-white">Contact</a>
    </nav>
    <nav aria-label="Legal" class="flex flex-col items-start gap-2">
      {links.map((l) => <a href={l.href} class="hover:text-white">{l.label}</a>)}
    </nav>
  </div>
  <div class="mx-auto mt-8 flex max-w-6xl flex-col gap-2 border-t border-white/10 pt-6 text-xs text-white/45 sm:flex-row sm:items-center sm:justify-between">
    <span>&copy; {year} {site.brand}. All rights reserved.</span>
    <span>Paddle processes eligible product payments.</span>
  </div>
</footer>
