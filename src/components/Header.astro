---
import PinkflowMark from './PinkflowMark.astro';

const navLinks = [
  { href: '/#products', label: 'Products' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/#company', label: 'Company' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="no-print sticky top-0 z-40 border-b border-primary/10 bg-bg-dark/95 backdrop-blur-md">
  <div class="mx-auto flex min-h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-lg font-extrabold tracking-tight text-white">
      <PinkflowMark compact />
      Pinkflow
    </a>
    <nav aria-label="Primary" class="hidden md:flex md:items-center md:gap-7 text-sm">
      {navLinks.map((l) => <a href={l.href} class="font-semibold text-white/70 hover:text-white">{l.label}</a>)}
    </nav>
    <button id="nav-toggle" aria-label="Toggle menu" aria-controls="mobile-nav" aria-expanded="false" class="inline-flex h-11 w-11 items-center justify-center rounded-lg text-white/70 hover:bg-white/5 hover:text-white md:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M3 6h18v2H3zm0 5h18v2H3zm0 5h18v2H3z"/></svg>
    </button>
  </div>
  <nav id="mobile-nav" aria-label="Mobile" class="hidden flex-col gap-1 border-t border-white/5 px-4 py-3 text-sm md:hidden">
    {navLinks.map((l) => <a href={l.href} class="rounded-lg px-3 py-3 font-semibold text-white/75 hover:bg-white/5 hover:text-white">{l.label}</a>)}
  </nav>
</header>
<script is:inline>
  const t = document.getElementById('nav-toggle');
  const m = document.getElementById('mobile-nav');
  if (t && m) {
    t.addEventListener('click', () => {
      const open = m.classList.toggle('hidden') === false;
      m.classList.toggle('flex', open);
      t.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    m.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        m.classList.add('hidden');
        m.classList.remove('flex');
        t.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
