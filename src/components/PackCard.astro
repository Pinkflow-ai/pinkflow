---
import type { SearchPack } from '../data/products';
interface Props { pack: SearchPack; ctaHref: string; }
const { pack, ctaHref } = Astro.props;
const price = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: Number.isInteger(pack.priceUsd) ? 0 : 2,
}).format(pack.priceUsd);
---
<article class={`card flex flex-col ${pack.popular ? 'shadow-neon-glow' : ''}`}>
  <div class="mb-4">
    <h3 class="text-lg font-extrabold text-white">{pack.searches} searches</h3>
    {pack.popular && (
      <span class="mt-2 inline-flex rounded-md bg-primary/20 px-2 py-1 text-[10px] font-extrabold uppercase text-primary">Best value</span>
    )}
    <p class="mt-2 text-3xl font-black text-white">{price}</p>
    <ul class="mt-3 space-y-1 text-xs text-white/60">
      {pack.includes.map((line) => <li class="flex gap-1.5"><span class="text-primary">✓</span> {line}</li>)}
    </ul>
  </div>
  <a href={ctaHref} class="btn-primary mt-auto w-full">Open Namescape</a>
</article>
