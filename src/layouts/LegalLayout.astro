---
import SiteLayout from './SiteLayout.astro';

interface Props {
  title: string;
  description?: string;
  lastUpdated?: string;
  path?: string;
}
const { title, description, lastUpdated, path = Astro.url.pathname } = Astro.props;
---
<SiteLayout
  title={title}
  description={description}
  path={path}
  mainClass="flex-1 px-4 py-12 sm:py-16"
>
  <div class="mx-auto max-w-5xl">
    <p class="mb-3 text-sm font-bold text-primary">Pinkflow company policy</p>
    <h1 class="max-w-4xl text-4xl font-extrabold leading-tight text-white sm:text-5xl">{title}</h1>
    {lastUpdated && (
      <p class="mt-3 text-sm text-white/60">Last updated: {lastUpdated}</p>
    )}
    <div class="mt-10"><slot /></div>
  </div>
</SiteLayout>
