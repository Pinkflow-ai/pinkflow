---
import LegalLayout from '../layouts/LegalLayout.astro';
---
<LegalLayout title="Not found" description="The page you were looking for does not exist.">
  <div class="mx-auto max-w-xl text-center">
    <p class="text-6xl font-extrabold text-primary">404</p>
    <p class="mt-4 text-lg text-white/70">We could not find that page.</p>
    <p class="mt-6 text-sm">
      <a href="/" class="btn-primary">Back to Pinkflow</a>
    </p>
  </div>
</LegalLayout>
