---
import SiteLayout from '../layouts/SiteLayout.astro';
import { site } from '../data/site';
import { gatewayCatalogCounts, gatewayCreditUsdMicros, gatewayEndpointPrices } from '../data/products';

const namescape = site.products.find((product) => product.slug === 'namescape')!;
const gateway = site.products.find((product) => product.slug === 'gateway')!;
const emailValidation = gatewayEndpointPrices.find((endpoint) => endpoint.name === 'Email validation')!;
const emailValidationUsd = (emailValidation.credits * gatewayCreditUsdMicros / 1_000_000).toFixed(3);
const description = 'Pinkflow.ai is building Namescape and Gateway.pink and publishing clear launch pricing, product limits, company policies, and direct contact details.';
---
<SiteLayout title="Pinkflow" description={description}>
  <section class="site-container flex min-h-[68vh] max-w-5xl items-center py-16 lg:py-24">
    <div class="max-w-4xl">
      <h1 class="max-w-4xl text-[clamp(1.75rem,8vw,6rem)] font-extrabold leading-[0.95] tracking-[-0.04em] text-white">
        Focused software for <span class="text-primary">stubborn work.</span>
      </h1>
      <p class="muted-copy mt-8 max-w-2xl text-lg leading-relaxed sm:text-xl">
        Pinkflow makes small, useful products around problems that are harder than they should be.
        This is where we keep the important details plain: what is being built, what it costs, and
        how to get in touch.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#products" class="btn-primary">See our products</a>
        <a href="/pricing" class="btn-secondary">Compare pricing</a>
      </div>
    </div>
  </section>

  <section id="products" class="scroll-mt-24 border-y border-white/10 py-20 sm:py-24">
    <div class="site-container">
      <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="mb-3 font-bold text-primary">Current products</p>
          <h2 class="section-title">Products with a clear job.</h2>
        </div>
        <p class="muted-copy max-w-md text-sm leading-relaxed sm:text-right">
          Each product is still in preparation. Prices are published for reference; checkout is not open yet.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <article class="product-panel flex flex-col">
          <div class="flex flex-wrap items-start justify-between gap-4 p-6 sm:p-8">
            <div class="min-w-0">
              <span class="status-chip">{namescape.statusLabel}</span>
              <h3 class="mt-4 text-[clamp(1.125rem,6vw,1.875rem)] font-extrabold text-white">Namescape.pink</h3>
              <p class="muted-copy mt-3 max-w-md leading-relaxed">Name ideas, domain research, and final checks for a shortlist you can act on.</p>
            </div>
            <span class="rounded-lg bg-white/5 px-3 py-2 text-right text-sm font-bold text-white">Free ideas at launch<br /><span class="text-xs font-medium text-white/55">Paid searches when checkout opens</span></span>
          </div>

          <div class="mx-6 rounded-lg bg-[#120d1a] p-5 sm:mx-8" aria-label="Namescape product flow">
            <p class="text-sm font-bold text-white">Free at launch: name ideas, brief help, and domain details.</p>
            <p class="mt-2 text-sm leading-relaxed text-white/60">Search packs cover the deeper generation and final-check work once checkout opens.</p>
          </div>

          <div class="mt-auto flex flex-wrap gap-3 p-6 sm:p-8">
            <a href="/pricing#namescape" class="btn-secondary">See search packs</a>
            <a href="/contact" class="btn-secondary">Contact Pinkflow</a>
          </div>
        </article>

        <article class="product-panel flex flex-col">
          <div class="flex flex-wrap items-start justify-between gap-4 p-6 sm:p-8">
            <div class="min-w-0">
              <span class="status-chip">{gateway.statusLabel}</span>
              <h3 class="mt-4 text-[clamp(1.125rem,6vw,1.875rem)] font-extrabold text-white"><span>Gateway.</span><wbr /><span>pink</span></h3>
              <p class="muted-copy mt-3 max-w-md leading-relaxed">{gateway.tagline}</p>
            </div>
            <span class="rounded-lg bg-white/5 px-3 py-2 text-right text-sm font-bold text-white">{gatewayCatalogCounts.freeAvailable} free APIs<br /><span class="text-xs font-medium text-white/55">{gatewayCatalogCounts.paidAvailable} paid in preview</span></span>
          </div>

          <div class="mx-6 overflow-hidden rounded-lg bg-[#120d1a] font-mono text-xs sm:mx-8" aria-label="Gateway example">
            <div class="p-5 font-sans">
              <p class="text-sm font-bold text-white">A real example</p>
              <p class="mt-2 text-sm leading-relaxed text-white/65">Validate an email address — {emailValidation.credits} credits (${emailValidationUsd}).</p>
            </div>
          </div>

          <div class="mt-auto flex flex-wrap gap-3 p-6 sm:p-8">
            <a href="/pricing#gateway" class="btn-secondary">See preview pricing</a>
            <a href="/contact" class="btn-secondary">Contact Pinkflow</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="company" class="site-container scroll-mt-24 py-20 sm:py-24">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="min-w-0">
        <p class="mb-3 font-bold text-primary">The company</p>
        <h2 class="section-title">Tools with a job to do.</h2>
      </div>
      <div class="muted-copy min-w-0 max-w-2xl space-y-5 text-lg leading-relaxed">
        <p>
          Pinkflow builds focused products for work that is often more complicated than it needs to be.
        </p>
        <p>
          The details matter. We keep product status, pricing, policies, and a real support address in one place.
          For questions, feedback, or a security report, email <a href={`mailto:${site.email}`} class="inline-link breakable-token">{site.email}</a> — we respond within {site.responseWindow}.
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-3 pt-2 text-sm font-bold">
          <a href="/terms">Terms</a>
          <a href="/privacy">Privacy</a>
          <a href="/refunds">Refunds</a>
          <a href="/contact">Contact</a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: site.brand,
    url: 'https://pinkflow.ai',
    email: site.email,
    foundingDate: site.founded,
    address: {
      '@type': 'PostalAddress',
      addressLocality: site.city,
      addressCountry: site.country,
    },
    owns: site.products.map((product) => ({
      '@type': 'SoftwareApplication',
      name: product.name,
      applicationCategory: 'WebApplication',
    })),
  })} />
</SiteLayout>
