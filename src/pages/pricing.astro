---
import SiteLayout from '../layouts/SiteLayout.astro';
import PackCard from '../components/PackCard.astro';
import {
  gatewayCreditPacks,
  gatewayAiBudgetPolicy,
  gatewayCatalogCounts,
  gatewayCreditUsdMicros,
  gatewayEndpointPrices,
  namescapePacks,
  namescapeUsagePrices,
} from '../data/products';
import { productActionHref, site } from '../data/site';

const description = 'Informational Namescape launch pricing and Gateway.pink developer-preview pricing. Checkout is unavailable, and Gateway.pink public API and documentation access are not currently open.';
const namescape = site.products.find((product) => product.slug === 'namescape')!;
const gateway = site.products.find((product) => product.slug === 'gateway')!;
const namescapeCheckoutUrl = productActionHref(namescape, 'checkout');
const usd = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
const usdPerCall = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  minimumFractionDigits: 3,
  maximumFractionDigits: 3,
});
const integer = new Intl.NumberFormat('en-US');
const creditUsd = gatewayCreditUsdMicros / 1_000_000;
---
<SiteLayout title="Pricing" description={description}>
  <section class="site-container pb-14 pt-16 sm:pb-20 sm:pt-24">
    <p class="mb-3 font-bold text-primary">Pinkflow pricing</p>
    <h1 class="max-w-4xl text-[clamp(1.75rem,7vw,5.8rem)] font-extrabold leading-[0.98] tracking-[-0.04em] text-white">
      Two products, two honest units.
    </h1>
    <p class="muted-copy mt-6 max-w-2xl text-lg leading-relaxed sm:text-xl">
      Namescape has included-free actions and uses searches only for completed search-priced actions. Gateway.pink uses fixed-value credits for APIs with real upstream cost. Neither product uses a subscription or auto-renewal.
    </p>
  </section>

  <section id="namescape" class="scroll-mt-24 border-y border-white/10 py-16 sm:py-20">
    <div class="site-container">
      <div class="grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
        <div class="min-w-0">
          <span class="status-chip">{namescape.statusLabel}</span>
          <h2 class="mt-4 text-[clamp(1.125rem,6vw,2.25rem)] font-extrabold text-white">Namescape search packs</h2>
          <p class="muted-copy mt-4 max-w-lg leading-relaxed">
            One-time balances for search-priced name ideas and final checks. Searches do not expire or auto-renew.
          </p>
        </div>
        <div class="min-w-0">
          <div class="grid gap-4 md:grid-cols-3">
            {namescapePacks.map((pack) => <PackCard pack={pack} ctaHref={namescapeCheckoutUrl} />)}
          </div>
          <p class="mt-4 rounded-lg border border-primary/20 bg-primary/[0.06] px-4 py-3 text-sm leading-relaxed text-[#d8cfdf]">
            <strong class="text-white">Namescape checkout is not currently available.</strong>{' '}
            These amounts are informational launch pricing, not an invitation to purchase today. Final tax and currency total shown at checkout will apply when purchasing opens.
          </p>
        </div>
      </div>

      <div class="mt-12 grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
        <div class="min-w-0">
          <h3 class="text-2xl font-extrabold text-white">How search usage works</h3>
          <p class="muted-copy mt-3 leading-relaxed">
            A search is the usage unit for one completed search-priced action. Included-free actions use no searches.
          </p>
          <p class="mt-3 text-sm text-white/55">
            Failed, empty, or indeterminate work does not use a search. Saving, revisiting, and copying an existing result are free.
          </p>
        </div>
        <div
          data-namescape-price-table-region=""
          class="min-w-0 overflow-hidden rounded-xl border border-white/10 bg-bg-card"
        >
          <table class="block w-full border-collapse text-left sm:table sm:table-fixed">
            <caption id="namescape-price-table-caption" class="block border-b border-white/10 px-5 py-4 text-left text-sm font-extrabold text-white sm:table-caption">
              Namescape action pricing
            </caption>
            <thead class="sr-only sm:not-sr-only sm:table-header-group">
              <tr class="border-b border-white/10 text-sm font-bold text-white/55">
                <th scope="col" class="px-5 py-3 sm:w-[18%]">Group</th>
                <th scope="col" class="px-5 py-3 sm:w-[30%]">Action</th>
                <th scope="col" class="px-5 py-3 text-right sm:w-[28%]">Price</th>
                <th scope="col" class="px-5 py-3 sm:w-[24%]">Note</th>
              </tr>
            </thead>
            <tbody class="block sm:table-row-group">
              {namescapeUsagePrices.map((item) => (
                <tr data-namescape-price-row="" class="grid grid-cols-1 gap-y-1 border-b border-white/10 px-5 py-4 align-top last:border-b-0 sm:table-row sm:p-0">
                  <td class="block min-w-0 break-words p-0 text-xs font-extrabold uppercase tracking-wide text-white/55 sm:table-cell sm:px-5 sm:py-4">{item.group}</td>
                  <th scope="row" class="block min-w-0 break-words p-0 text-left font-semibold text-white sm:table-cell sm:px-5 sm:py-4">{item.name}</th>
                  <td class="block min-w-0 break-words p-0 text-left font-bold text-primary sm:table-cell sm:px-5 sm:py-4 sm:text-right">{item.price}</td>
                  <td class="block min-w-0 break-words p-0 text-xs font-medium text-white/55 sm:table-cell sm:px-5 sm:py-4">
                    {item.note ?? <span class="sr-only">No additional note</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <p class="mt-8 max-w-4xl text-sm leading-relaxed text-white/60">
        All prices are USD. Domain availability, registrar pricing, taxes, and legal clearance must be confirmed independently.
      </p>
    </div>
  </section>

  <section id="gateway" class="scroll-mt-24 py-16 sm:py-20">
    <div class="site-container">
      <div class="grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
        <div class="min-w-0">
          <span class="status-chip">{gateway.statusLabel}</span>
          <h2 class="mt-4 text-[clamp(1.125rem,6vw,2.25rem)] font-extrabold text-white"><span>Gateway.</span><wbr /><span>pink credits</span></h2>
          <p class="muted-copy mt-4 max-w-lg leading-relaxed">
            Published developer-preview pricing for {gatewayCatalogCounts.freeAvailable} free routes and {gatewayCatalogCounts.paidAvailable} paid routes implemented in the developer-preview catalog. Public API and documentation access is not currently open. The credit denomination does not change between packs.
          </p>
          <div class="mt-6 max-w-full rounded-lg bg-primary/10 px-4 py-3 text-lg font-extrabold text-[#ff9dcc]">
            1 credit = $0.001
          </div>
        </div>

        <div class="min-w-0">
          <div class="min-w-0 overflow-hidden rounded-xl border border-white/10 bg-bg-card">
            <div class="hidden grid-cols-[1fr_auto_auto] gap-4 border-b border-white/10 px-5 py-3 text-sm font-bold text-white/55 sm:grid">
              <span>Pack</span><span class="text-right">Credits</span><span class="text-right">Price</span>
            </div>
            {gatewayCreditPacks.map((pack) => (
              <div class="grid min-w-0 grid-cols-1 items-center gap-1 border-b border-white/10 px-5 py-4 last:border-b-0 sm:grid-cols-[1fr_auto_auto] sm:gap-4">
                <span class="font-semibold text-white">{pack.name}{pack.mcpAccess && <span class="ml-2 hidden text-xs font-bold text-primary sm:inline">MCP access</span>}</span>
                <span class="text-sm text-white/70 sm:text-right">{integer.format(pack.credits)} credits</span>
                <span class="font-extrabold text-white sm:min-w-14 sm:text-right">{usd.format(pack.priceUsd)}</span>
              </div>
            ))}
          </div>
          <p class="mt-4 rounded-lg border border-primary/20 bg-primary/[0.06] px-4 py-3 text-sm leading-relaxed text-[#d8cfdf]">
            <strong class="text-white">Gateway.pink credit checkout is not currently available.</strong>{' '}
            These are published preview prices for budgeting during the developer preview, not an invitation to purchase today.
          </p>
        </div>
      </div>

      <div class="mt-12 grid gap-8 lg:grid-cols-[0.7fr_1.3fr]">
        <div class="min-w-0">
          <h3 class="text-2xl font-extrabold text-white">What paid calls cost</h3>
          <p class="muted-copy mt-3 leading-relaxed">
            Free routes consume zero credits. Fixed-price routes settle only after a successful provider response. AI settles from actual provider-reported cost; browser preview routes settle from reported browser milliseconds. <code>{gatewayAiBudgetPolicy.field}</code> is the AI caller's hard credit ceiling ({gatewayAiBudgetPolicy.minimum}–{gatewayAiBudgetPolicy.maximum} credits).
          </p>
        </div>
        <div class="min-w-0">
          <div class="overflow-hidden rounded-xl border border-white/10 bg-bg-card">
            <div class="hidden grid-cols-[1fr_auto_auto] gap-4 border-b border-white/10 px-5 py-3 text-sm font-bold text-white/55 sm:grid">
              <span>Paid route</span><span class="text-right">Credits</span><span class="text-right">Dollars</span>
            </div>
            {gatewayEndpointPrices.map((item) => (
              <div class="grid min-w-0 grid-cols-1 gap-1 border-b border-white/10 px-5 py-4 last:border-b-0 sm:grid-cols-[1fr_auto_auto] sm:gap-4">
                <span class="font-semibold text-white">{item.name}{item.preview && <span class="ml-2 text-xs text-white/55">Preview</span>}</span>
                <span class="font-bold text-primary sm:text-right">
                  {item.maximumCredits ? `${item.credits}–${item.maximumCredits}` : `${item.metered ? 'From ' : ''}${item.credits}`} {item.maximumCredits === 1 || (!item.maximumCredits && item.credits === 1) ? 'credit' : 'credits'}
                </span>
                <span class="text-sm text-white/70 sm:min-w-28 sm:text-right">
                  {item.maximumCredits
                    ? `${usdPerCall.format(item.credits * creditUsd)}–${usdPerCall.format(item.maximumCredits * creditUsd)} / call`
                    : `${usdPerCall.format(item.credits * creditUsd)} ${item.metered ? 'minimum' : '/ call'}`}
                </span>
              </div>
            ))}
          </div>
          <p class="mt-4 text-sm leading-relaxed text-white/60">
            Direct or high-volume provider plans may have lower unit prices. Gateway.pink is designed for low-commitment access across providers: one key, one balance, and no mandatory monthly subscription.
          </p>
          <p class="mt-3 text-sm leading-relaxed text-white/60">
            Paid requests require a unique <code>Idempotency-Key</code>. Provider failures, timeouts, and invalid provider responses charge zero. Browser routes remain preview-only until live invoice data confirms the published metering ceiling.
          </p>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="/terms" class="btn-secondary">Read the service terms</a>
      </div>
    </div>
  </section>

  <section class="site-container border-t border-white/10 py-12 text-sm text-white/55">
    <p>
      Questions about pricing or a billing issue? Contact <a href={`mailto:${site.email}`} class="inline-link">{site.email}</a>.
      See our <a href="/terms" class="inline-link">Terms of Service</a> and <a href="/refunds" class="inline-link">Refund Policy</a>.
    </p>
  </section>

</SiteLayout>
